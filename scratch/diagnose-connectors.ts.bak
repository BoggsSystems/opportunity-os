import { prisma } from '../../packages/db/src';

async function diagnose() {
  console.log('--- DIAGNOSIS START ---');
  
  // 1. Check CapabilityProviders
  const providers = await prisma.capabilityProvider.findMany({
    select: { providerName: true, displayName: true }
  });
  console.log('Registered Providers:', providers);

  // 2. Check current user's connectors
  // We'll look for the most recent user
  const user = await prisma.user.findFirst({
    orderBy: { createdAt: 'desc' },
    include: {
      userConnectors: {
        include: {
          capabilityProvider: true
        }
      }
    }
  });

  if (!user) {
    console.log('No user found in database.');
  } else {
    console.log(`Diagnosis for User: ${user.email} (${user.id})`);
    console.log('Connectors found:', user.userConnectors.map(c => ({
      provider: c.capabilityProvider.providerName,
      status: c.status,
      name: c.connectorName
    })));
  }

  console.log('--- DIAGNOSIS END ---');
}

diagnose().catch(console.error);
