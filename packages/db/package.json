{
  "name": "@opportunity-os/db",
  "version": "0.1.0",
  "description": "Database client and schema for Opportunity OS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node --loader ts-node/esm prisma/seeds/seed-esm.mjs",
    "db:reset": "prisma migrate reset --force",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@opportunity-os/config": "workspace:*",
    "@opportunity-os/types": "workspace:*",
    "@prisma/client": "^5.9.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^5.9.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "tsx prisma/seeds/seed-clean.ts"
  }
}
