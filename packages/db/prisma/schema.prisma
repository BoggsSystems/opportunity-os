model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  fullName        String?
  avatarUrl       String?
  timezone        String?
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions        Subscription[]
  billingCustomers     BillingCustomer[]
  billingEvents        BillingEvent[]
  entitlementOverrides EntitlementOverride[]
  usageCounters        UsageCounter[]
  usageRecords         UsageRecord[]
  identities           AuthenticationIdentity[]
  sessions             AuthenticationSession[]
  verificationTokens   VerificationToken[]

  companies                    Company[]
  people                       Person[]
  opportunities                Opportunity[]
  activities                   Activity[]
  goals                        Goal[]
  campaigns                    Campaign[]
  tasks                        Task[]
  notes                        Note[]
  tags                         Tag[]
  searchProfiles               SearchProfile[]
  discoveryScans               DiscoveryScan[]
  discoveryTargets             DiscoveryTarget[]
  connectionImportBatches      ConnectionImportBatch[]
  connectionRecords            ConnectionRecord[]
  connectionSegments           ConnectionSegment[]
  browserSessions              BrowserSession[]
  offerings                    Offering[]
  offeringProposals            OfferingProposal[]
  conversations                AIConversation[]
  summaries                    AIContextSummary[]
  aiTasks                      AITask[]
  assets                       UserAsset[]
  workspaceSignals             WorkspaceSignal[]
  opportunityCycles            OpportunityCycle[]
  workspaceCommands            WorkspaceCommand[]
  userConnectors               UserConnector[]
  referralLinks                ReferralLink[]
  referralAttributionsGiven    ReferralAttribution[]       @relation("ReferralReferrer")
  referralAttributionsReceived ReferralAttribution[]       @relation("ReferralReferred")
  referralVisitsGiven          ReferralVisit[]             @relation("ReferralVisitReferrer")
  referralVisitsConverted      ReferralVisit[]             @relation("ReferralVisitReferred")
  referralRewards              ReferralReward[]
  growthCredits                GrowthCredit[]
  goalProgress                 GoalProgress[]
  weeklyTargets                WeeklyTarget[]
  momentumStates               MomentumState[]
  coachingNudges               CoachingNudge[]
  campaignMetrics              CampaignMetric[]
  actionItems                  ActionItem[]
  dailyCommandQueues           DailyCommandQueue[]
  commandQueueItems            CommandQueueItem[]
  conversationThreads          ConversationThread[]
  conversationMessages         ConversationThreadMessage[]
  conversationInsights         ConversationThreadInsight[]
  campaignTargetQueueItems     CampaignTargetQueueItem[]
  strategicTheses              StrategicThesis[]
  userPosture                  UserPosture?
  calendarEvents               CalendarEvent[]
  technicalProfiles            TechnicalProfile[]
  lifecycleEvents              UserLifecycleEvent[]
  lifecycleSnapshot            UserLifecycleSnapshot?
  adminOperationalIssues       AdminOperationalIssue[]
  externalMappings             ExternalMapping[]
  engagementLogs               UserEngagementLog[]
  engagementRewards            EngagementReward[]
   notifications                Notification[]
  concepts                     Concept[]
  proofPoints                  ProofPoint[]
  intelligenceUsage            IntelligenceUsage[]
  connectorAssets              ConnectorAsset[]
  assetIngestionBatches        AssetIngestionBatch[]
  assetIngestionItems          AssetIngestionItem[]
  ingestionArtifacts           IngestionArtifact[]
  intelligenceJobs             IntelligenceJob[]
  intelligenceChunks           IntelligenceChunk[]
  intelligenceEmbeddings       IntelligenceEmbedding[]

  @@map("users")
}

model Notification {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @db.Uuid
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  channel          NotificationChannel
  status           NotificationStatus  @default(pending)
  eventKey         String              @db.VarChar(100)
  
  subject          String?             @db.VarChar(255)
  body             String              @db.Text
  metadataJson     Json?
  
  providerName     String?             @db.VarChar(50)
  providerMessageId String?            @db.VarChar(255)
  
  error            String?             @db.Text
  
  readAt           DateTime?
  sentAt           DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([userId, status])
  @@index([eventKey])
  @@map("notifications")
}

model UserEngagementLog {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  nudgeType       String    @db.VarChar(100) // e.g., 'ghost_campaign', 'milestone_reached'
  strategyVersion String?   @db.VarChar(50) // To track which AI prompt style worked better
  sentAt          DateTime  @default(now())
  openedAt        DateTime?
  clickedAt       DateTime?
  convertedAt     DateTime? // e.g., timestamp when they upgraded after this email

  metadataJson Json? // Store the context we used (like campaign ID or signal IDs)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nudgeType])
  @@index([sentAt])
  @@map("user_engagement_logs")
}

model ExternalMapping {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  localEntityType String // e.g., 'Person', 'Opportunity', 'Conversation'
  localEntityId   String   @db.Uuid
  remoteProvider  String // e.g., 'hubspot', 'salesforce', 'pipedrive'
  remoteEntityId  String // The ID in the external system
  remoteUrl       String? // Optional direct link to the record in the CRM
  syncStatus      String   @default("synced") // 'synced', 'failed', 'stale'
  lastSyncedAt    DateTime @default(now())
  metadataJson    Json? // Stores provider-specific mapping details

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localEntityType, localEntityId, remoteProvider])
  @@index([localEntityType, localEntityId])
  @@map("external_mappings")
}

model AuthenticationIdentity {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  identityType        String    @default("email")
  email               String
  emailNormalized     String    @unique
  isPrimary           Boolean   @default(true)
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?
  lastAuthenticatedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials        Credential[]
  sessions           AuthenticationSession[]
  verificationTokens VerificationToken[]

  @@index([userId])
  @@map("authentication_identities")
}

model Credential {
  id                       String                       @id @default(uuid()) @db.Uuid
  authenticationIdentityId String                       @db.Uuid
  credentialType           AuthenticationCredentialType
  passwordHash             String?
  providerName             String?
  providerAccountId        String?
  accessToken              String?
  refreshToken             String?
  expiresAt                DateTime?
  passwordVersion          Int                          @default(1)
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

  authenticationIdentity AuthenticationIdentity @relation(fields: [authenticationIdentityId], references: [id], onDelete: Cascade)

  @@unique([providerName, providerAccountId])
  @@index([authenticationIdentityId])
  @@map("credentials")
}

model AuthenticationSession {
  id                       String                      @id @default(uuid()) @db.Uuid
  userId                   String                      @db.Uuid
  authenticationIdentityId String?                     @db.Uuid
  status                   AuthenticationSessionStatus @default(active)
  clientType               String
  deviceName               String?
  userAgent                String?
  ipAddress                String?                     @db.Inet
  refreshTokenHash         String
  expiresAt                DateTime
  lastUsedAt               DateTime?
  revokedAt                DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  authenticationIdentity AuthenticationIdentity? @relation(fields: [authenticationIdentityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([authenticationIdentityId])
  @@index([userId, status])
  @@index([expiresAt])
  @@map("authentication_sessions")
}

model VerificationToken {
  id                       String                @id @default(uuid()) @db.Uuid
  userId                   String?               @db.Uuid
  authenticationIdentityId String?               @db.Uuid
  tokenType                VerificationTokenType
  tokenHash                String
  expiresAt                DateTime
  consumedAt               DateTime?
  createdAt                DateTime              @default(now())

  user                   User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  authenticationIdentity AuthenticationIdentity? @relation(fields: [authenticationIdentityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([authenticationIdentityId])
  @@index([tokenType])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model Plan {
  id                   String   @id @default(uuid()) @db.Uuid
  code                 String   @unique
  name                 String
  description          String?
  monthlyPriceCents    Int      @default(0)
  annualPriceCents     Int      @default(0)
  currency             String   @default("USD")
  stripeProductId      String?
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  isActive             Boolean  @default(true)
  metadataJson         Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  planFeatures        PlanFeature[]
  subscriptions       Subscription[]
  modelAccessPolicies ModelAccessPolicy[]

  @@map("plans")
}

model BillingCustomer {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @db.Uuid
  provider           String                @default("stripe")
  providerCustomerId String
  email              String
  status             BillingCustomerStatus @default(active)
  metadataJson       Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([provider, providerCustomerId])
  @@index([userId])
  @@index([providerCustomerId])
  @@index([status])
  @@map("billing_customers")
}

model PlanFeature {
  id          String             @id @default(uuid()) @db.Uuid
  planId      String             @db.Uuid
  featureKey  String
  accessLevel FeatureAccessLevel
  configJson  Json?
  createdAt   DateTime           @default(now())

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
  @@map("plan_features")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  userId                 String             @db.Uuid
  planId                 String             @db.Uuid
  billingCustomerId      String?            @db.Uuid
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  providerPriceId        String?
  status                 SubscriptionStatus
  billingInterval        String?
  startedAt              DateTime
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  trialEndsAt            DateTime?
  endedAt                DateTime?
  metadataJson           Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan             @relation(fields: [planId], references: [id], onDelete: Restrict)
  billingCustomer BillingCustomer? @relation(fields: [billingCustomerId], references: [id], onDelete: SetNull)

  @@unique([providerSubscriptionId])
  @@index([userId])
  @@index([planId])
  @@index([billingCustomerId])
  @@index([providerCustomerId])
  @@index([providerPriceId])
  @@index([status])
  @@map("subscriptions")
}

model BillingEvent {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String?            @db.Uuid
  provider        String             @default("stripe")
  providerEventId String
  eventType       String
  status          BillingEventStatus @default(received)
  payloadJson     Json
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([userId])
  @@index([eventType])
  @@index([status])
  @@index([processedAt])
  @@map("billing_events")
}

model UsageCounter {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  featureKey       String
  usagePeriodStart DateTime  @db.Date
  usagePeriodEnd   DateTime  @db.Date
  usedCount        Int       @default(0)
  resetAt          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey, usagePeriodStart, usagePeriodEnd])
  @@index([userId])
  @@index([featureKey])
  @@map("usage_counters")
}

model UsageRecord {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  featureKey     String
  metricCode     String
  quantity       Int      @default(1)
  idempotencyKey String?
  sourceType     String?
  sourceId       String?  @db.Uuid
  occurredAt     DateTime @default(now())
  windowStart    DateTime @db.Date
  windowEnd      DateTime @db.Date
  metadataJson   Json?
  createdAt      DateTime @default(now())

