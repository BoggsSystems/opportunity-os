  @@index([offeringId])
  @@index([campaignId])
  @@index([actionLaneId])
  @@index([actionCycleId])
  @@index([actionItemId])
  @@index([status])
  @@index([scheduledFor])
  @@index([priorityScore])
  @@index([userId, status, priorityScore])
