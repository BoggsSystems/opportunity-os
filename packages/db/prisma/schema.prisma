  status               ActionItemStatus              @default(suggested)
  confirmationRequired Boolean                       @default(true)
  confirmationSource   ActionItemConfirmationSource?
  priorityScore        Int                           @default(50)
  dueAt                DateTime?
  preparedAt           DateTime?
  openedAt             DateTime?
  completedAt          DateTime?
  skippedAt            DateTime?
  respondedAt          DateTime?
  metadataJson         Json?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actionLane       ActionLane        @relation(fields: [actionLaneId], references: [id], onDelete: Cascade)
  actionCycle      ActionCycle?      @relation(fields: [actionCycleId], references: [id], onDelete: SetNull)
  activity         Activity?         @relation(fields: [activityId], references: [id], onDelete: SetNull)
  workspaceCommand WorkspaceCommand? @relation(fields: [workspaceCommandId], references: [id], onDelete: SetNull)
  targetPerson     Person?           @relation("PersonActionItems", fields: [targetPersonId], references: [id], onDelete: SetNull)
  targetCompany    Company?          @relation("CompanyActionItems", fields: [targetCompanyId], references: [id], onDelete: SetNull)
  conversationThreads ConversationThread[]

  @@index([userId])
  @@index([campaignId])
  @@index([actionLaneId])
  @@index([actionCycleId])
  @@index([activityId])
  @@index([workspaceCommandId])
  @@index([targetType, targetId])
  @@index([targetPersonId])
  @@index([targetCompanyId])
  @@index([actionType])
  @@index([status])
  @@index([dueAt])
  @@index([completedAt])
  @@index([campaignId, status, priorityScore])
  @@index([actionLaneId, status, priorityScore])
  @@map("action_items")
}

model ConversationThread {
  id                   String                   @id @default(uuid()) @db.Uuid
  userId               String                   @db.Uuid
  campaignId           String?                  @db.Uuid
  actionLaneId         String?                  @db.Uuid
  actionCycleId        String?                  @db.Uuid
  actionItemId         String?                  @db.Uuid
  targetPersonId       String?                  @db.Uuid
  targetCompanyId      String?                  @db.Uuid
  channel              String
  externalProvider     String?
  externalThreadUrl    String?
  status               ConversationThreadStatus @default(active)
  latestSummary        String?
  latestSentiment      ConversationInsightSentiment @default(unknown)
  latestIntent         String?
  nextActionSummary    String?
  lastMessageAt        DateTime?
  metadataJson         Json?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign      Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  actionLane    ActionLane?  @relation(fields: [actionLaneId], references: [id], onDelete: SetNull)
  actionCycle   ActionCycle? @relation(fields: [actionCycleId], references: [id], onDelete: SetNull)
  actionItem    ActionItem?  @relation(fields: [actionItemId], references: [id], onDelete: SetNull)
  targetPerson  Person?      @relation("PersonConversationThreads", fields: [targetPersonId], references: [id], onDelete: SetNull)
  targetCompany Company?     @relation("CompanyConversationThreads", fields: [targetCompanyId], references: [id], onDelete: SetNull)
  messages      ConversationThreadMessage[]
  insights      ConversationThreadInsight[]

  @@index([userId])
  @@index([campaignId])
  @@index([actionLaneId])
  @@index([actionCycleId])
  @@index([actionItemId])
  @@index([targetPersonId])
  @@index([targetCompanyId])
  @@index([channel])
  @@index([status])
  @@index([lastMessageAt])
  @@map("conversation_threads")
}

model ConversationThreadMessage {
  id              String                       @id @default(uuid()) @db.Uuid
  userId          String                       @db.Uuid
  threadId        String                       @db.Uuid
  direction       ConversationMessageDirection
  source          ConversationMessageSource    @default(manual_paste)
  bodyText        String?
  attachmentUrls  String[]
  attachmentMimeTypes String[]
  occurredAt      DateTime                     @default(now())
  metadataJson    Json?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([threadId])
  @@index([direction])
  @@index([source])
  @@index([occurredAt])
  @@map("conversation_thread_messages")
}

model ConversationThreadInsight {
  id                    String                       @id @default(uuid()) @db.Uuid
  userId                String                       @db.Uuid
  threadId              String                       @db.Uuid
  summary               String
  sentiment             ConversationInsightSentiment @default(unknown)
  intent                String?
  objections            String[]
  buyingSignals         String[]
  recommendedNextAction String?
  suggestedActionType   String?
  suggestedActionItemId String?                      @db.Uuid
  evidenceMessageIds    String[]
  metadataJson          Json?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([threadId])
  @@index([sentiment])
  @@index([suggestedActionType])
  @@index([suggestedActionItemId])
  @@map("conversation_thread_insights")
}

model CampaignMetric {
  id              String    @id @default(uuid()) @db.Uuid
  campaignId      String?   @db.Uuid
  actionLaneId    String?   @db.Uuid
  userId          String    @db.Uuid
  metricType      String
  metricValue     Decimal
  metricUnit      String?
  periodStart     DateTime?
  periodEnd       DateTime?
  comparisonValue Decimal?
  trendDirection  String?
  computedAt      DateTime  @default(now())
  metadataJson    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  actionLane ActionLane? @relation(fields: [actionLaneId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([actionLaneId])
  @@index([userId])
  @@index([metricType])
  @@index([campaignId, metricType, periodStart])
  @@index([actionLaneId, metricType, periodStart])
  @@index([computedAt])
  @@map("campaign_metrics")
}
