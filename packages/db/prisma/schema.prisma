  @@index([campaignId])
  @@index([actionLaneId])
  @@index([personId])
  @@index([connectionRecordId])
  @@index([status])
  @@unique([campaignId, personId])
  @@unique([campaignId, connectionRecordId])
  @@map("campaign_target_queue_items")
}
