  priorityScore        Int                           @default(50)
  dueAt                DateTime?
  preparedAt           DateTime?
  openedAt             DateTime?
  completedAt          DateTime?
  skippedAt            DateTime?
  respondedAt          DateTime?
  metadataJson         Json?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign            Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actionLane          ActionLane           @relation(fields: [actionLaneId], references: [id], onDelete: Cascade)
  actionCycle         ActionCycle?         @relation(fields: [actionCycleId], references: [id], onDelete: SetNull)
  activity            Activity?            @relation(fields: [activityId], references: [id], onDelete: SetNull)
  workspaceCommand    WorkspaceCommand?    @relation(fields: [workspaceCommandId], references: [id], onDelete: SetNull)
  targetPerson        Person?              @relation("PersonActionItems", fields: [targetPersonId], references: [id], onDelete: SetNull)
  targetCompany       Company?             @relation("CompanyActionItems", fields: [targetCompanyId], references: [id], onDelete: SetNull)
  conversationThreads ConversationThread[]
  commandQueueItems   CommandQueueItem[]
  intelligenceUsage   IntelligenceUsage[]

  @@index([userId])
  @@index([campaignId])
  @@index([actionLaneId])
  @@index([actionCycleId])
  @@index([activityId])
  @@index([workspaceCommandId])
  @@index([targetType, targetId])
  @@index([targetPersonId])
  @@index([targetCompanyId])
  @@index([actionType])
  @@index([status])
  @@index([dueAt])
  @@index([completedAt])
  @@index([campaignId, status, priorityScore])
  @@index([actionLaneId, status, priorityScore])
  @@map("action_items")
}

model DailyCommandQueue {
