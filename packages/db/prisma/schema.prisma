model Concept {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @db.Uuid
  title        String
  category     ConceptCategory
  description  String
  isPromoted   Boolean         @default(false)
  metadataJson Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user         User            @relation(fields: [userId], references: [id])
  sources      IntelligenceSource[] @relation("ConceptSources")
  proofLinks   ConceptProofLink[]
  parents      ConceptRelationship[] @relation("ConceptChildren")
  children     ConceptRelationship[] @relation("ConceptParents")
  refinements  ConceptRefinement[]
  usages       IntelligenceUsage[]

  @@map("concepts")
}

model ProofPoint {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @db.Uuid
  title        String
  content      String
  isPromoted   Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user         User            @relation(fields: [userId], references: [id])
  sources      IntelligenceSource[] @relation("ProofPointSources")
  conceptLinks ConceptProofLink[]
  usages       IntelligenceUsage[]

  @@map("proof_points")
}

model IntelligenceSource {
  id           String            @id @default(uuid()) @db.Uuid
  conceptId    String?           @db.Uuid
  proofPointId String?           @db.Uuid
  chunkId      String?           @db.Uuid
  sourceType   ConceptSourceType
  sourceId     String
  createdAt    DateTime          @default(now())

  concept      Concept?          @relation("ConceptSources", fields: [conceptId], references: [id])
  proofPoint   ProofPoint?       @relation("ProofPointSources", fields: [proofPointId], references: [id])
  chunk        IntelligenceChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@index([chunkId])
  @@map("intelligence_sources")
}

model ConceptRelationship {
  parentId         String @db.Uuid
  childId          String @db.Uuid
  relationshipType String?

  parent Concept @relation("ConceptParents", fields: [parentId], references: [id])
  child  Concept @relation("ConceptChildren", fields: [childId], references: [id])

  @@id([parentId, childId])
  @@map("concept_relationships")
}

model ConceptProofLink {
  conceptId    String @db.Uuid
  proofPointId String @db.Uuid

  concept    Concept    @relation(fields: [conceptId], references: [id])
  proofPoint ProofPoint @relation(fields: [proofPointId], references: [id])

  @@id([conceptId, proofPointId])
  @@map("concept_proof_links")
}

model IntelligenceUsage {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  conceptId    String?  @db.Uuid
  proofPointId String?  @db.Uuid
  actionItemId String?  @db.Uuid
  sentiment    Float?
  outcome      String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  concept      Concept? @relation(fields: [conceptId], references: [id])
  proofPoint   ProofPoint? @relation(fields: [proofPointId], references: [id])
  actionItem   ActionItem? @relation(fields: [actionItemId], references: [id])

  @@map("intelligence_usage")
}

model ConceptRefinement {
  id             String   @id @default(uuid()) @db.Uuid
  conceptId      String   @db.Uuid
  oldValue       String?
  newValue       String
  refinementType String   // "user_edit", "ai_learned"
  createdAt      DateTime @default(now())

  concept        Concept  @relation(fields: [conceptId], references: [id])

  @@map("concept_refinements")
}

enum CampaignTargetStatus {
  PROPOSED
  SKIPPED
  SELECTED
  CONVERTED
}

model CampaignTargetQueueItem {
  id                 String               @id @default(uuid()) @db.Uuid
  userId             String               @db.Uuid
  campaignId         String               @db.Uuid
  actionLaneId       String?              @db.Uuid
  personId           String?              @db.Uuid
  connectionRecordId String?              @db.Uuid
  score              Int                  @default(0)
  rationale          String?
  criteria           String?
  status             CampaignTargetStatus @default(PROPOSED)
