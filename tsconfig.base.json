{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": false,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@opportunity-os/config": ["./packages/config/src"],
      "@opportunity-os/db": ["./packages/db/src"],
      "@opportunity-os/types": ["./packages/types/src"],
      "@opportunity-os/ui-contracts": ["./packages/ui-contracts/src"],
      "@opportunity-os/auth": ["./packages/auth/src"],
      "@opportunity-os/logger": ["./packages/logger/src"],
      "@opportunity-os/queue": ["./packages/queue/src"],
      "@opportunity-os/ai": ["./packages/ai/src"],
      "@opportunity-os/integrations": ["./packages/integrations/src"],
      "@opportunity-os/common": ["./packages/common/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
